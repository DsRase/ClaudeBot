{
  "title": "ClaudeBot",
  "uid": "claudebot-main",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },
  "timezone": "browser",
  "panels": [
    {
      "id": 1,
      "title": "CPU Usage",
      "type": "stat",
      "gridPos": { "x": 0, "y": 0, "w": 6, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus-uid" },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 70 },
              { "color": "red", "value": 90 }
            ]
          }
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" },
      "targets": [
        {
          "expr": "100 - (avg(rate(node_cpu_seconds_total{mode=\"idle\"}[2m])) * 100)",
          "legendFormat": "CPU"
        }
      ]
    },
    {
      "id": 2,
      "title": "RAM Usage",
      "type": "stat",
      "gridPos": { "x": 6, "y": 0, "w": 6, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus-uid" },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 70 },
              { "color": "red", "value": 90 }
            ]
          }
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" },
      "targets": [
        {
          "expr": "(1 - (node_memory_MemAvailable_bytes / node_memory_MemTotal_bytes)) * 100",
          "legendFormat": "RAM"
        }
      ]
    },
    {
      "id": 3,
      "title": "Disk Usage",
      "type": "stat",
      "gridPos": { "x": 12, "y": 0, "w": 6, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus-uid" },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 75 },
              { "color": "red", "value": 90 }
            ]
          }
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" },
      "targets": [
        {
          "expr": "(1 - (node_filesystem_avail_bytes{mountpoint=\"/\",fstype!=\"tmpfs\"} / node_filesystem_size_bytes{mountpoint=\"/\",fstype!=\"tmpfs\"})) * 100",
          "legendFormat": "Disk /"
        }
      ]
    },
    {
      "id": 4,
      "title": "Redis Memory",
      "type": "stat",
      "gridPos": { "x": 18, "y": 0, "w": 6, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus-uid" },
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "blue", "value": null }]
          }
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" },
      "targets": [
        {
          "expr": "redis_memory_used_bytes",
          "legendFormat": "Used"
        }
      ]
    },
    {
      "id": 5,
      "title": "Network I/O",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 4, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus-uid" },
      "fieldConfig": {
        "defaults": { "unit": "Bps" },
        "overrides": [
          { "matcher": { "id": "byName", "options": "TX" }, "properties": [{ "id": "custom.transform", "value": "negative-Y" }] }
        ]
      },
      "options": { "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "expr": "rate(node_network_receive_bytes_total{device!~\"lo|docker.*|veth.*\"}[2m])",
          "legendFormat": "RX {{device}}"
        },
        {
          "expr": "rate(node_network_transmit_bytes_total{device!~\"lo|docker.*|veth.*\"}[2m])",
          "legendFormat": "TX {{device}}"
        }
      ]
    },
    {
      "id": 6,
      "title": "Bot & LLM Requests / min",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 4, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus-uid" },
      "fieldConfig": { "defaults": { "unit": "reqpm" } },
      "options": { "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "expr": "rate(bot_messages_total{status=\"triggered\"}[1m]) * 60",
          "legendFormat": "Bot triggered"
        },
        {
          "expr": "rate(bot_messages_total{status=\"success\"}[1m]) * 60",
          "legendFormat": "Bot success"
        },
        {
          "expr": "rate(llm_requests_total{status=\"success\"}[1m]) * 60",
          "legendFormat": "LLM success"
        },
        {
          "expr": "rate(llm_requests_total{status=\"error\"}[1m]) * 60",
          "legendFormat": "LLM error"
        }
      ]
    },
    {
      "id": 7,
      "title": "LLM Request Duration",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 12, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus-uid" },
      "fieldConfig": { "defaults": { "unit": "s" } },
      "options": { "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, rate(llm_request_duration_seconds_bucket[5m]))",
          "legendFormat": "p50 {{model}}"
        },
        {
          "expr": "histogram_quantile(0.95, rate(llm_request_duration_seconds_bucket[5m]))",
          "legendFormat": "p95 {{model}}"
        }
      ]
    },
    {
      "id": 8,
      "title": "LLM Status Codes",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 12, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus-uid" },
      "fieldConfig": { "defaults": { "unit": "short" } },
      "options": { "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "expr": "rate(llm_status_codes_total[5m])",
          "legendFormat": "{{status_code}} / {{model}}"
        }
      ]
    },
    {
      "id": 9,
      "title": "Redis Operations / min",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 20, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus-uid" },
      "fieldConfig": { "defaults": { "unit": "reqpm" } },
      "options": { "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "expr": "rate(redis_operations_total[1m]) * 60",
          "legendFormat": "{{operation}} / {{status}}"
        },
        {
          "expr": "rate(redis_commands_processed_total[1m]) * 60",
          "legendFormat": "Redis total commands"
        }
      ]
    },
    {
      "id": 10,
      "title": "DB Queries / min",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 20, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus-uid" },
      "fieldConfig": { "defaults": { "unit": "reqpm" } },
      "options": { "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "expr": "rate(db_queries_total[1m]) * 60",
          "legendFormat": "{{operation}} / {{status}}"
        }
      ]
    },
    {
      "id": 11,
      "title": "Application Logs",
      "type": "logs",
      "gridPos": { "x": 0, "y": 28, "w": 24, "h": 10 },
      "datasource": { "type": "loki", "uid": "loki-uid" },
      "options": {
        "dedupStrategy": "none",
        "enableLogDetails": true,
        "prettifyLogMessage": false,
        "showTime": true,
        "wrapLogMessage": false
      },
      "targets": [
        {
          "expr": "{service=\"bot\"}",
          "legendFormat": ""
        }
      ]
    }
  ]
}
